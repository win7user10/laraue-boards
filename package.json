{
  "name": "laraue-boards-new-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev --public",
    "typecheck": "nuxt typecheck && vue-tsc -p tsconfig.test.json",
    "lint": "oxlint && eslint .",
    "lint:fix": "oxlint --fix && eslint . --fix",
    "format": "oxfmt --check",
    "format:fix": "oxfmt",
    "style": "stylelint \"**/*.{css,vue}\"",
    "style:fix": "stylelint \"**/*.{css,vue}\" --fix",
    "fix": "pnpm lint:fix && pnpm format:fix && pnpm style:fix",
    "test": "vitest run",
    "api": "openapi-typescript http://localhost:5200/openapi/v1.json -o infrastructure/api/generated.ts",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "pre-commit": "pnpm fix && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@dnd-kit/abstract": "^0.5.0",
    "@dnd-kit/dom": "^0.5.0",
    "@dnd-kit/helpers": "^0.5.0",
    "@dnd-kit/vue": "^0.5.0",
    "es-toolkit": "^1.49.0",
    "lucide-vue-next": "^1.0.0",
    "nuxt": "^4.4.8",
    "nuxt-gtag": "4.1.0",
    "openapi-fetch": "^0.15.0",
    "vue": "^3.5.39",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^10.7.0",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-vue": "^10.9.2",
    "openapi-typescript": "^7.10.1",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "postcss-html": "^1.8.1",
    "stylelint": "^17.14.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  }
}
