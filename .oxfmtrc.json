{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": ["infrastructure/api/generated.ts"],
  "arrowParens": "always",
  "bracketSameLine": true,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "htmlWhitespaceSensitivity": "ignore",
  "printWidth": 100,
  "proseWrap": "always",
  "semi": false,
  "singleAttributePerLine": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "sortImports": true,
  "sortPackageJson": true
}
